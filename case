private void sendMail(String email,
                      Set<String> branchCode,
                      List<TradeInfo> pendingTrades) {

    Template temp = new Template();

    String branches = String.join(", ", branchCode);

    StringBuilder tradeRows = new StringBuilder();

    for (TradeInfo trade : pendingTrades) {

        tradeRows.append("<tr>")
                 .append("<td>").append(trade.getTradeNumber()).append("</td>")
                 .append("<td>").append(trade.getTradeDate()).append("</td>")
                 .append("<td>").append(trade.getBranchCode()).append("</td>")
                 .append("</tr>");
    }

    Map<String, String> data = new HashMap<>();

    data.put("branchCode", branches);
    data.put("pendingTradeCount",
             String.valueOf(pendingTrades.size()));
    data.put("tradeRows",
             tradeRows.toString());

    String htmlContent =
            prepareTemplate(temp.getHtmlTemplate(),
                            data,
                            data.size());

    Map<String, Object> jsonPayload = new HashMap<>();

    jsonPayload.put("mailContent", htmlContent);

    jsonPayload.put("mailSubject",
            "Pending Accounting Trades Notification");

    jsonPayload.put("sourceSystem", "rForex");

    jsonPayload.put("mailRecipients", email);

    jsonPayload.put("mailContentWithFileNames", null);

    HttpHeaders headers = new HttpHeaders();
    headers.setContentType(MediaType.APPLICATION_JSON);

    RestTemplate restTemplate = new RestTemplate();

    HttpEntity<Map<String, Object>> entity =
            new HttpEntity<>(jsonPayload, headers);

    String response =
            restTemplate.exchange(
                    mailUrl,
                    HttpMethod.POST,
                    entity,
                    String.class)
                    .getBody();

    System.out.println(response);
}

